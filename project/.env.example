# The Watcher — Environment Configuration
# Copy this file to .env and adjust values for your machine.

# ── Directories ──────────────────────────────────────────────────────────────
# Use absolute paths OUTSIDE of OneDrive / synced folders to avoid
# Windows Defender / OneDrive holding locks on segment files.
#
# WatcherData\
#   segments\      ← rolling MPEG-TS buffer (auto-pruned, SEGMENT_DIR)
#   clips_raw\     ← individual per-monitor MP4s, one file per screen (RAW_CLIPS_DIR)
#   clips\         ← combined multi-monitor MP4 + timestamp overlay (CLIPS_DIR)
#
#SEGMENT_DIR=C:\WatcherData\segments
#CLIPS_DIR=C:\WatcherData\clips
#RAW_CLIPS_DIR=C:\WatcherData\clips_raw

# ── Recording retention ───────────────────────────────────────────────────────
# RETENTION_HOURS — how many hours of raw segments to keep on disk (rolling buffer).
RETENTION_HOURS=8

# SEGMENT_DURATION — length of each raw MPEG-TS segment file in seconds.
# The clip builder assembles segments into clips; SEGMENT_DURATION controls
# how often a new segment file starts, which sets the minimum clip granularity.
#
# Rule of thumb: set SEGMENT_DURATION == CLIP_WINDOW_MINUTES * 60
# so each clip window contains exactly one segment.
#
#   ── Production (default) ──────────────────────────────────────────
SEGMENT_DURATION=300         # 5-minute segments
CLIP_WINDOW_MINUTES=60       # close and start a new clip every 60 minutes
CLIP_MAX_SIZE_MB=3072        # also close if clip would exceed 3 GB
#
#   ── Testing — uncomment to verify clip creation in ~1 minute ──────
#SEGMENT_DURATION=60         # 1-minute segments
#CLIP_WINDOW_MINUTES=1       # 1-minute clips — you'll see logs within seconds
#CLIP_MAX_SIZE_MB=50         # also test size-based overflow at 50 MB

# ── Capture ──────────────────────────────────────────────────────────────────
# "desktop" captures the full screen via gdigrab.
# To capture a specific window use its title, e.g.: CAPTURE_SOURCE=title=Chrome
CAPTURE_SOURCE=desktop
CAPTURE_FRAMERATE=30
OUTPUT_WIDTH=1920
OUTPUT_HEIGHT=1080

# ── Encoding ─────────────────────────────────────────────────────────────────
# CRF / constant-quality: lower = better quality / larger files (0–51, default 28)
CRF=28

# VIDEO_CODEC — "hevc" (H.265, ~40–50% smaller at equal quality) or "h264".
# Applies to both the live recorder and offline clip assembly. If no HEVC
# encoder is available it falls back to H.264 automatically.
# In-app playback (Qt FFmpeg backend) supports HEVC; external players may need
# the Windows "HEVC Video Extensions". Use "h264" for fleets without HEVC.
VIDEO_CODEC=hevc

# ── Combined multi-monitor grid ───────────────────────────────────────────────
# The combined clip (clips/) packs every monitor into one grid for review and
# is re-encoded — its resolution is the dominant size driver. Per-monitor raw
# clips (clips_raw/) keep full OUTPUT_WIDTH/HEIGHT regardless.
# Each grid cell is scaled to COMBINED_CELL_WIDTH×HEIGHT (default 1280×720 →
# a 2×2 grid is 2560×1440 instead of 4K). COMBINED_QUALITY is the CRF/-cq/
# -global_quality target for the grid (higher = smaller).
COMBINED_CELL_WIDTH=1280
COMBINED_CELL_HEIGHT=720
COMBINED_QUALITY=27

# ── Roles ────────────────────────────────────────────────────────────────────
# IT_PIN — PIN required for an IT admin to unlock role-change access on
# Operator/Supervisor PCs (Ctrl+Alt+Shift+R in the app). Change before deploying.
IT_PIN=1234

# ── Supervisor / IT request system ───────────────────────────────────────────
# UNC host of the shared storage where operator footage lives.
SLC_STORAGE_HOST=\\SIG-SLC-Storage
# Port the IT PC WebSocket server listens on (Supervisors send requests here).
IT_WS_PORT=9090

# ── NAS credentials (network share auth) ──────────────────────────────────────
# Used by the in-app clip browser to authenticate \\SLC_STORAGE_HOST via
# `net use` when browsing footage. Leave BLANK to use the current Windows
# user's credentials (no explicit auth). NEVER commit a real password — keep
# secrets only in your local .env, which is gitignored.
NAS_USERNAME=
NAS_PASSWORD=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Event / clip timing ───────────────────────────────────────────────────────
# Seconds of post-event footage captured before the clip is assembled (default: 120)
#EVENT_POST_SECONDS=120
# Seconds of pre-event footage included in the clip (default: 120)
#EVENT_PRE_SECONDS=120
# Minimum seconds between two accepted events (cooldown, default: 30)
#EVENT_COOLDOWN_SECONDS=30
# Seconds between clip-build retry attempts when assembly fails (default: 30)
#CLIP_RETRY_DELAY_SECONDS=30
